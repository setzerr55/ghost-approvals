# === REQUIRED ===

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Alchemy API key — used for eth_call (allowance refresh) and token metadata.
# eth_getLogs on Alchemy's Free tier is capped at 10 blocks per request, so we
# do not rely on it for approval discovery; Etherscan V2 is used instead.
ALCHEMY_API_KEY=

# Etherscan V2 API key — used to fetch Approval events across all 6 chains
# via the unified endpoint. https://etherscan.io/myapikey
ETHERSCAN_API_KEY=

# Groq API key for AI explanations (free tier)
GROQ_API_KEY=


# === OPTIONAL ===

# GoPlus API (for malicious contract detection, free tier — no key needed for basic)
GOPLUS_API_KEY=

# Public base URL (used in shareable score cards)
PUBLIC_BASE_URL=https://ghostapprovals.xyz

# SQLite path
DB_PATH=./data/ghost.db

# Log level
LOG_LEVEL=INFO
